{% macro file_row() %}
    <li class="loaded_file">
        <span {{ stimulus_action('pdf-field-input', 'deleteNew') }}
              data-pdf-field-input-filename-param="__FILENAME__"
              class="loaded_file__remove">&times;</span>
        <span class="loaded_file__name">__FILENAME__</span>
        <span class="loaded_file__size">(__FILESIZE__)</span>
    </li>
{% endmacro %}

{% block app_pdf_field_widget %}
    {% set existing_files = existing_files|default([]) %}
    <div id="app_pdf_field" {{ stimulus_controller('pdf-field-input') }}>
        {{ form_widget(form, {id: "app_pdf_field_input", attr: {
            'data-pdf-field-input-target': 'fileInput',
            'data-action': 'change->pdf-field-input#fileChanged',
        }}) }}
        <div class="loaded_files_header">Fichiers</div>
        {% if existing_files is not empty %}
            <ul class="loaded_files_existing" {{ stimulus_target('pdf-field-input', 'existingFileList') }}>
                {% for file in existing_files %}
                    <li class="loaded_file">
                        <span {{ stimulus_action('pdf-field-input', 'deleteExisting') }}
                              data-pdf-field-input-file-param="{{ file | json_encode }}"
                              class="loaded_file__remove">&times;</span>
                        <a href="{{ webpath(file) }}" target="_blank" class="loaded_file__name loaded_file__link">{{ file.name }}</a>
                        <span class="loaded_file__size">({{ filesize(file) }})</span>
                    </li>
                {% endfor %}
            </ul>
        {% endif %}
        <p class="loaded_files_empty" {{ stimulus_target('pdf-field-input', 'emptyMessage') }}
           {% if existing_files is not empty %}style="display: none"{% endif %}>Pas de fichiers</p>
        <ul class="loaded_files" {{ stimulus_target('pdf-field-input', 'fileList') }} style="display: none"></ul>
        <input type="hidden" id="app_pdf_field_kept" name="app_pdf_field_kept"
               {{ stimulus_target('pdf-field-input', 'kept') }}
               value="{{ existing_files | json_encode }}">
        <input type="hidden" id="app_pdf_field_removed" name="app_pdf_field_removed"
               {{ stimulus_target('pdf-field-input', 'removed') }}
               value="{{ [] | json_encode }}">
        <template {{ stimulus_target('pdf-field-input', 'template') }}>
            {{ _self.file_row() }}
        </template>
    </div>
{% endblock %}


{% block app_autocomplete_widget %}
    {{ form_widget(form, {'attr': {
        'data-controller': 'autocomplete-field-input',
        'data-autocomplete-field-input-choices-value': form.vars.choices | json_encode,
        'data-autocomplete-field-input-separator-value': form.vars.separator ?? ',',
        'data-autocomplete-field-input-create-value': form.vars.create ? 'true' : 'false',
        'data-autocomplete-field-input-multiple-value': form.vars.multiple ? 'true' : 'false',
    }}) }}
{% endblock %}


{# ─── Table collection ──────────────────────────────────────────────────────
   table_collection_row    : sets data-* attrs on the row container; calls
                             block('form_row') for the outer structure.
   table_collection_widget : renders existing entries as <tr> rows, plus a
                             <template> holding the prototype row (avoids
                             HTML-attribute escaping).
   ─────────────────────────────────────────────────────────────────────────── #}

{% block table_collection_row %}
    {# Compute num-items #}
    {% set maxKey = 0 %}
    {% for key in form.children|keys %}
        {% if key matches '/^\\d+$/' %}
            {% set intKey = key|number_format(0, '', '', '') %}
            {% if intKey > maxKey %}{% set maxKey = intKey %}{% endif %}
        {% endif %}
    {% endfor %}

    {# row_attr is a PHP array — stimulus_controller() outputs a string, so
       the controller and its values must be set as individual data attributes #}
    {% set row_attr = row_attr|merge({
        'data-controller': 'collection-table',
        'data-allow-add': allow_add|default(false) ? 'true' : 'false',
        'data-allow-delete': allow_delete|default(false) ? 'true' : 'false',
        'data-collection-table-allow-sort-value': allow_sort|default(false) ? 'true' : 'false',
        'data-collection-table-num-items-value': form.children is empty ? 0 : maxKey + 1,
        'data-collection-table-name-placeholder-value': form.vars.prototype is defined ? form.vars.prototype.vars.name : '',
    }) %}

    {{ block('form_row') }}
{% endblock %}

{% block table_collection_widget %}
    <table class="table table-sm table-collection">
        <thead>
            <tr>
                {% if allow_sort|default(false) %}<th class="table-collection-col-sort"></th>{% endif %}
                {% if allow_delete|default(false) %}<th class="table-collection-col-delete"></th>{% endif %}
                {% for child in form.vars.prototype %}
                    {% if child.vars.block_prefixes|filter(p => p starts with 'ea_form_')|length == 0 %}
                        <th>{{ child.vars.label ?? child.vars.name|humanize }}</th>
                    {% endif %}
                {% endfor %}
            </tr>
        </thead>
        <tbody {{ stimulus_target('collection-table', 'body') }}>
            {% for entry in form %}
                <tr data-row-index="{{ loop.index0 }}">
                    {% if allow_sort|default(false) %}
                        <td class="table-collection-col-sort">
                            <i class="fa fa-grip-vertical drag-handle" title="Drag to reorder"></i>
                        </td>
                    {% endif %}
                    {% if allow_delete|default(false) %}
                        <td class="table-collection-col-delete">
                            <button type="button" class="btn btn-sm btn-outline-danger"
                                    {{ stimulus_action('collection-table', 'delete') }} title="Remove">
                                <i class="fa fa-trash"></i>
                            </button>
                        </td>
                    {% endif %}
                    {% for child in entry %}
                        {% if child.vars.block_prefixes|filter(p => p starts with 'ea_form_')|length == 0 %}
                            <td>{{ form_widget(child) }}{{ form_errors(child) }}</td>
                        {% endif %}
                    {% endfor %}
                    <td style="display:none">{{ form_rest(entry) }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
    {% if form.vars.prototype is defined %}
        {% set proto = form.vars.prototype %}
        <template {{ stimulus_target('collection-table', 'prototype') }}>
            <tr data-row-index="__index__">
                {% if allow_sort|default(false) %}
                    <td class="table-collection-col-sort">
                        <i class="fa fa-grip-vertical drag-handle" title="Drag to reorder"></i>
                    </td>
                {% endif %}
                {% if allow_delete|default(false) %}
                    <td class="table-collection-col-delete">
                        <button type="button" class="btn btn-sm btn-outline-danger"
                                {{ stimulus_action('collection-table', 'delete') }} title="Remove">
                            <i class="fa fa-trash"></i>
                        </button>
                    </td>
                {% endif %}
                {% for child in proto %}
                    {% if child.vars.block_prefixes|filter(p => p starts with 'ea_form_')|length == 0 %}
                        <td>{{ form_widget(child) }}</td>
                    {% endif %}
                {% endfor %}
                <td style="display:none">{{ form_rest(proto) }}</td>
            </tr>
        </template>
    {% endif %}
    {% if allow_add|default(false) %}
        <button type="button" class="btn btn-sm btn-outline-secondary mt-2"
                {{ stimulus_action('collection-table', 'add') }}>
            <i class="fa fa-plus"></i> Add item
        </button>
    {% endif %}
{% endblock %}
