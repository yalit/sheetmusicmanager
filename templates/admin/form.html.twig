{% macro file_row() %}
    <li class="loaded_file">
        <span data-file-remove="__FILENAME__" class="loaded_file__remove">&times;</span>
        <span class="loaded_file__name">__FILENAME__</span>
        <span class="loaded_file__size">(__FILESIZE__)</span>
    </li>
{% endmacro %}

{% block app_pdf_field_widget %}
    {% set existing_files = existing_files|default([]) %}
    <div id="app_pdf_field">
        {{ form_widget(form, {id:"app_pdf_field_input"}) }}
        <div class="loaded_files_header">Fichiers</div>
        {% if existing_files is not empty %}
            <ul class="loaded_files_existing">
                {% for file in existing_files %}
                    <li class="loaded_file">
                        <span data-existing-remove="{{ file.name }}" class="loaded_file__remove">&times;</span>
                        <a href="{{ file.web_path }}" target="_blank" class="loaded_file__name loaded_file__link">{{ file.name }}</a>
                        <span class="loaded_file__size">({{ file.size }})</span>
                    </li>
                {% endfor %}
            </ul>
        {% endif %}
        <p class="loaded_files_empty" {% if existing_files is not empty %}style="display: none"{% endif %}>Pas de fichiers</p>
        <ul class="loaded_files" style="display: none">
        </ul>
        <input type="hidden" id="app_pdf_field_kept" name="app_pdf_field_kept"
               value="{{ existing_files|map(f => f.name)|json_encode|e('html_attr') }}">
        <input type="hidden" id="app_pdf_field_removed" name="app_pdf_field_removed"
               value="{{ []|json_encode|e('html_attr') }}">
    </div>
    <template id="pdf_field_file">
        {{ _self.file_row() }}
    </template>
{% endblock %}


{% block app_autocomplete_widget %}
    {{ form_widget(form, {'attr': {
        'autocomplete': true,
        'data-choices': form.vars.choices | json_encode,
        'data-separator': form.vars.separator ?? ',',
        'data-create': form.vars.create ?? '',
        'data-multiple': form.vars.multiple ?? ''
    }}) }}
{% endblock %}


{# ─── Table collection ──────────────────────────────────────────────────────
   table_collection_row    : sets data-* attrs on the row container; calls
                             block('form_row') for the outer structure.
   table_collection_widget : renders existing entries as <tr> rows, plus a
                             <template data-table-prototype> holding the
                             prototype row (avoids HTML-attribute escaping).
   ─────────────────────────────────────────────────────────────────────────── #}

{% block table_collection_row %}
    {# Compute num-items #}
    {% set maxKey = 0 %}
    {% for key in form.children|keys %}
        {% if key matches '/^\\d+$/' %}
            {% set intKey = key|number_format(0, '', '', '') %}
            {% if intKey > maxKey %}{% set maxKey = intKey %}{% endif %}
        {% endif %}
    {% endfor %}

    {% set row_attr = row_attr|merge({
        'data-table-collection-field': 'true',
        'data-allow-add': allow_add|default(false) ? 'true' : 'false',
        'data-allow-delete': allow_delete|default(false) ? 'true' : 'false',
        'data-num-items': form.children is empty ? 0 : maxKey + 1,
        'data-form-type-name-placeholder': form.vars.prototype is defined ? form.vars.prototype.vars.name : '',
    }) %}

    {{ block('form_row') }}
{% endblock %}

{% block table_collection_widget %}
    <table class="table table-sm table-collection">
        <thead>
            <tr>
                {% if allow_delete|default(false) %}<th class="table-collection-col-delete"></th>{% endif %}
                {% for child in form.vars.prototype %}
                    {% if child.vars.block_prefixes|filter(p => p starts with 'ea_form_')|length == 0 %}
                        <th>{{ child.vars.label ?? child.vars.name|humanize }}</th>
                    {% endif %}
                {% endfor %}
            </tr>
        </thead>
        <tbody data-table-collection-body>
            {% for entry in form %}
                <tr>
                    {% if allow_delete|default(false) %}
                        <td class="table-collection-col-delete">
                            <button type="button" class="btn btn-sm btn-outline-danger table-collection-delete" title="Remove">
                                <i class="fa fa-trash"></i>
                            </button>
                        </td>
                    {% endif %}
                    {% for child in entry %}
                        {% if child.vars.block_prefixes|filter(p => p starts with 'ea_form_')|length == 0 %}
                            <td>{{ form_widget(child) }}{{ form_errors(child) }}</td>
                        {% endif %}
                    {% endfor %}
                    <td style="display:none">{{ form_rest(entry) }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
    {% if form.vars.prototype is defined %}
        {% set proto = form.vars.prototype %}
        <template data-table-prototype>
            <tr>
                {% if allow_delete|default(false) %}
                    <td class="table-collection-col-delete">
                        <button type="button" class="btn btn-sm btn-outline-danger table-collection-delete" title="Remove">
                            <i class="fa fa-trash"></i>
                        </button>
                    </td>
                {% endif %}
                {% for child in proto %}
                    {% if child.vars.block_prefixes|filter(p => p starts with 'ea_form_')|length == 0 %}
                        <td>{{ form_widget(child) }}</td>
                    {% endif %}
                {% endfor %}
                <td style="display:none">{{ form_rest(proto) }}</td>
            </tr>
        </template>
    {% endif %}
    {% if allow_add|default(false) %}
        <button type="button" class="btn btn-sm btn-outline-secondary table-collection-add mt-2">
            <i class="fa fa-plus"></i> Add item
        </button>
    {% endif %}
{% endblock %}
